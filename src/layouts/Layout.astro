---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'PlayField Sport Center — Sewa Lapangan Futsal, Badminton, Padel & Tenis',
  description = 'Sport center dengan 12 lapangan: futsal, badminton, padel, dan tenis. Booking online 24 jam, buka 06.00–23.00, fasilitas lengkap. Member hemat up to 30%.',
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google Fonts: Bebas Neue + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body style="overflow-x: hidden;">
    <slot />
  </body>
</html>
