---
// Icons rendered via inline SVG strings (Tabler) — Astro static component
const menuIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>`;

const navLinks = [
  { href: '#lapangan', label: 'Lapangan' },
  { href: '#padel', label: 'Padel' },
  { href: '#harga', label: 'Harga' },
  { href: '#member', label: 'Member' },
  { href: '#tournament', label: 'Tournament' },
  { href: '#lokasi', label: 'Lokasi' },
];

const WA_NUMBER = '6281234567890';
const WA_MESSAGE = encodeURIComponent('Halo, saya ingin book lapangan di PlayField Sport Center.');
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: rgba(18,18,18,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid #2a2a2a;"
>
  <div class="container-main">
    <nav class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div
          class="w-8 h-8 rounded-lg flex items-center justify-center font-display text-lg font-bold"
          style="background: #f97316; color: #fff;"
        >
          P
        </div>
        <span class="font-display text-xl tracking-wide" style="color: #fff;">
          PLAY<span style="color: #f97316;">FIELD</span>
        </span>
      </a>

      <!-- Nav Links (desktop) -->
      <ul class="hidden md:flex items-center gap-7">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-medium transition-colors duration-200 hover:text-white"
              style="color: #b3b3b3; font-family: var(--font-sans);"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA -->
      <div class="flex items-center gap-3">
        <a
          href={`https://wa.me/${WA_NUMBER}?text=${WA_MESSAGE}`}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 text-sm font-bold uppercase tracking-wider rounded-full transition-all duration-200 hover:scale-105 active:scale-95"
          style="background: #ffffff; color: #111111; font-family: var(--font-sans); letter-spacing: 0.05em;"
        >
          Book Lapangan
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="md:hidden flex items-center justify-center p-2 text-white"
          aria-label="Menu"
          set:html={menuIcon}
        />
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden px-5 pb-5"
    style="border-top: 1px solid #2a2a2a;"
  >
    <ul class="flex flex-col gap-4 pt-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-base font-medium"
            style="color: #b3b3b3;"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href={`https://wa.me/${WA_NUMBER}?text=${WA_MESSAGE}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full justify-center items-center px-5 py-3 text-sm font-bold uppercase tracking-wider rounded-full"
          style="background: #ffffff; color: #111111;"
        >
          Book Lapangan
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close mobile menu on nav link click
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => menu.classList.add('hidden'));
  });
</script>
